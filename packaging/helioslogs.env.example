# HeliosLogs service environment — copy to /etc/helioslogs/helioslogs.env and edit.
# Read by the systemd unit via EnvironmentFile=. All values are optional.
# reference of available parameters can be found under https://docs.helioslogs.com/deploy/configuration and https://docs.helioslogs.com/deploy/tuning 

# Raw syslog listener port (UDP + TCP; default 5514, 0 disables). Sets the port only —
# enable the listener under Admin -> Data Ingestion -> Syslog.
#export HELIOS_SYSLOG_PORT="5514"
