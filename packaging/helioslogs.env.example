# HeliosLogs service environment — copy to /etc/helioslogs/helioslogs.env and edit.
# Read by the systemd unit via EnvironmentFile=. All values are optional.

# First-run admin bootstrap (creates the initial admin account on an empty install).
#HELIOS_ADMIN_EMAIL=you@example.com
#HELIOS_ADMIN_PASSWORD=change-me

# Toggle control-plane encryption off (default on, key at HELIOS_CONTROL_KEY_PATH).
#HELIOS_CONTROL_ENCRYPTION=0

# Log verbosity (tracing env-filter syntax).
#RUST_LOG=info
